# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

SERVER_PORT=3001
NODE_ENV=development

# Generate each with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=replace-me-with-a-64-char-hex-string

# LLM provider config
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (get free key at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── MCP Servers (optional) ────────────────────────────────────────────────────
# MCP (Model Context Protocol) lets the agent use tools from external servers.
# Format: JSON object where each key is a friendly name you choose.
#
# GitHub MCP server setup:
#   1. Go to github.com → Settings → Developer settings → Personal access tokens
#   2. Generate a token with "repo" and "read:org" scopes
#   3. Paste it below as GITHUB_TOKEN
#
# Then set MCP_SERVERS to wire it in:
GITHUB_TOKEN=ghp_your_token_here
MCP_SERVERS={"github":{"command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_TOKEN":"ghp_your_token_here"}}}
