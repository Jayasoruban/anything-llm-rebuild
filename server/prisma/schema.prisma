// Prisma schema — defines the database shape for anything-llm-rebuild.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../storage/anythingllm.db"
}

// Who can log into the app. First user registered becomes the admin.
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("default")   // "admin" | "default"
  suspended Boolean  @default(false)       // admin can lock a user out
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats          WorkspaceChat[]
  workspaces     WorkspaceUser[]
  threads        Thread[]
  claimedInvites Invite[]        @relation("ClaimedInvites")
  createdInvites Invite[]        @relation("CreatedInvites")
}

// Global app settings (key-value store).
model SystemSettings {
  id        Int      @id @default(autoincrement())
  label     String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A chat container. One workspace groups many related Q&A pairs.
model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chats     WorkspaceChat[]
  documents WorkspaceDocument[]
  members   WorkspaceUser[]
  threads   Thread[]
}

// Join table: which users have access to which workspaces.
// Admin bypasses this check and always has access to all workspaces.
model WorkspaceUser {
  id          Int      @id @default(autoincrement())
  userId      Int
  workspaceId Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// One-time-use invite tokens. Admin generates → shares URL → user registers.
model Invite {
  id        Int      @id @default(autoincrement())
  token     String   @unique   // uuid — used in the invite URL
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  createdById Int
  claimedById Int?

  createdBy User  @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: Cascade)
  claimedBy User? @relation("ClaimedInvites", fields: [claimedById], references: [id], onDelete: SetNull)
}

// A named conversation inside a workspace.
// Each user can have many threads per workspace — each thread has its own
// isolated chat history. The slug (uuid) is used in API paths.
model Thread {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  userId      Int?
  name        String   @default("New Thread")
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  chats     WorkspaceChat[]
}

// One row = one uploaded document (metadata only — vectors live in LanceDB).
model WorkspaceDocument {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  docId       String   @unique
  title       String
  mimeType    String
  wordCount   Int
  chunkCount  Int
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// One row = one Q&A pair (user prompt + assistant response).
// threadId is optional — chats without a thread belong to the workspace's "default" context.
model WorkspaceChat {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  userId      Int?
  threadId    Int?
  prompt      String
  response    String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  thread    Thread?   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([threadId])
}
