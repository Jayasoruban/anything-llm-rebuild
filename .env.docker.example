# ============================================================================
#  .env.docker.example — Environment variables for Docker deployment
# ============================================================================
#  1. Copy this file to server/.env
#  2. Fill in every value marked REPLACE_ME
#  3. Never commit server/.env to git (it's already in .gitignore)
#
#  Generate secure random secrets:
#    openssl rand -hex 32   →  JWT_SECRET   (64 hex chars)
#    openssl rand -hex 32   →  ENCRYPTION_KEY (64 hex chars)
# ============================================================================

SERVER_PORT=3001
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_ME_run_openssl_rand_hex_32
ENCRYPTION_KEY=REPLACE_ME_run_openssl_rand_hex_32

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI — required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — ALWAYS required (used for embeddings regardless of LLM_PROVIDER)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── MCP (optional — remove these two lines if not using GitHub tools) ─────────
GITHUB_TOKEN=ghp_...
MCP_SERVERS={"github":{"command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_TOKEN":"ghp_your_token_here"}}}
